{
  "name": "polaris-design",
  "version": "0.0.1",
  "description": "폴라리스 디자인 시스템 일관성 강제 — 바이브코딩옵스에서 만들어지는 React/Next.js 웹 서비스의 토큰·컴포넌트 사용을 자동 검증",
  "author": "Polaris Office",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/post-edit-lint.mjs\""
          }
        ]
      }
    ]
  }
}

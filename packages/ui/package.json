{
  "name": "@polaris/ui",
  "version": "0.7.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js",
      "require": "./dist/tokens/index.cjs"
    },
    "./tailwind": {
      "types": "./dist/tailwind/index.d.ts",
      "import": "./dist/tailwind/index.js",
      "require": "./dist/tailwind/index.cjs"
    },
    "./form": {
      "types": "./dist/form/index.d.ts",
      "import": "./dist/form/index.js",
      "require": "./dist/form/index.cjs"
    },
    "./ribbon": {
      "types": "./dist/ribbon/index.d.ts",
      "import": "./dist/ribbon/index.js",
      "require": "./dist/ribbon/index.cjs"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js",
      "require": "./dist/icons/index.cjs"
    },
    "./file-icons": {
      "types": "./dist/file-icons/index.d.ts",
      "import": "./dist/file-icons/index.js",
      "require": "./dist/file-icons/index.cjs"
    },
    "./logos": {
      "types": "./dist/logos/index.d.ts",
      "import": "./dist/logos/index.js",
      "require": "./dist/logos/index.cjs"
    },
    "./ribbon-icons": {
      "types": "./dist/ribbon-icons/index.d.ts",
      "import": "./dist/ribbon-icons/index.js",
      "require": "./dist/ribbon-icons/index.cjs"
    },
    "./styles/tokens.css": "./src/styles/tokens.css",
    "./styles/v4-theme.css": "./src/styles/v4-theme.css"
  },
  "files": [
    "dist",
    "src/styles/tokens.css",
    "src/styles/v4-theme.css"
  ],
  "sideEffects": [
    "**/*.css",
    "src/styles/tokens.css",
    "src/styles/v4-theme.css"
  ],
  "scripts": {
    "build": "pnpm build:tokens && pnpm build:design-md && pnpm build:icons && pnpm build:file-icons && pnpm build:logos && pnpm build:ribbon-icons && tsup",
    "build:tokens": "tsx scripts/build-tokens.ts",
    "build:design-md": "tsx scripts/build-design-md.ts",
    "build:icons": "tsx scripts/build-icons.ts",
    "build:file-icons": "tsx scripts/build-file-icons.ts",
    "build:logos": "tsx scripts/build-logos.ts",
    "build:ribbon-icons": "tsx scripts/build-ribbon-icons.ts",
    "normalize:icons": "tsx scripts/normalize-icon-names.ts",
    "dev": "tsup --watch",
    "typecheck": "pnpm gen:sources && tsc --noEmit",
    "test": "pnpm gen:sources && vitest run && node --test 'test/**/*.test.mjs'",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo src/icons src/file-icons src/logos src/ribbon-icons",
    "gen:sources": "pnpm build:tokens && pnpm build:icons && pnpm build:file-icons && pnpm build:logos && pnpm build:ribbon-icons",
    "prepare": "pnpm gen:sources"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-toggle-group": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.469.0",
    "react-day-picker": "^9.4.4",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-hook-form": "^7.50.0",
    "tailwindcss": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    }
  }
}

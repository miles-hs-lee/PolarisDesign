# Playwright run artifacts (HTML report + per-run output) — baselines
# in e2e/__screenshots__/ ARE committed for visual regression diffing.
playwright-report/
test-results/

# Figma source file — exceeds GitHub's 100MB file limit. Source of
# truth lives in the design team's Figma workspace; the .fig export
# stays local for offline reference.
figma/*.fig

# Auto-generated icon / logo / file-icon components — regenerate via
# `pnpm --filter @polaris/ui build`. Source SVGs live in `assets/svg/`
# (also gitignored — design team's Figma is the canonical source).
packages/ui/src/icons/
packages/ui/src/file-icons/
packages/ui/src/logos/

# Synced from assets/figma-spec via `pnpm --filter demo sync:figma-spec`
# (auto-runs predev / prebuild). Source of truth lives in assets/.
apps/demo/public/figma-spec/
